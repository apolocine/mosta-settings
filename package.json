{
  "name": "@mostajs/settings",
  "version": "2.1.0",
  "description": "Reusable key-value settings module with typed factory, React provider and auto-generated form",
  "author": "Dr Hamid MADANI <drmdh@msn.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components/SettingsProvider": {
      "types": "./dist/components/SettingsProvider.d.ts",
      "import": "./dist/components/SettingsProvider.js",
      "default": "./dist/components/SettingsProvider.js"
    },
    "./components/SettingsForm": {
      "types": "./dist/components/SettingsForm.d.ts",
      "import": "./dist/components/SettingsForm.js",
      "default": "./dist/components/SettingsForm.js"
    },
    "./hooks/useSettings": {
      "types": "./dist/hooks/useSettings.d.ts",
      "import": "./dist/hooks/useSettings.js",
      "default": "./dist/hooks/useSettings.js"
    },
    "./lib/menu": {
      "types": "./dist/lib/menu.d.ts",
      "import": "./dist/lib/menu.js",
      "default": "./dist/lib/menu.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js",
      "default": "./dist/register.js"
    },
    "./lib/module-info": {
      "types": "./dist/lib/module-info.d.ts",
      "import": "./dist/lib/module-info.js",
      "default": "./dist/lib/module-info.js"
    },
    "./lib/scoped-settings": {
      "types": "./dist/lib/scoped-settings.d.ts",
      "import": "./dist/lib/scoped-settings.js",
      "default": "./dist/lib/scoped-settings.js"
    }
  },
  "files": [
    "dist",
    "wire.json",
    "settings.wire.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "settings",
    "configuration",
    "key-value",
    "admin",
    "nextjs",
    "react",
    "mosta"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/apolocine/mosta-settings"
  },
  "homepage": "https://mostajs.dev/packages/settings",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mostajs/net": "^2.0.0",
    "@mostajs/octoswitcher": "^1.0.0",
    "@mostajs/orm": "^1.7.0"
  },
  "peerDependencies": {
    "@mostajs/menu": ">=1.0.2",
    "@mostajs/socle": ">=2.0.0",
    "next": ">=14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "@mostajs/menu": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mostajs/menu": "^1.0.2",
    "@mostajs/socle": "^2.0.0",
    "@types/react": "^19.0.0",
    "lucide-react": "^1.7.0",
    "next": "^16.1.6",
    "react": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
